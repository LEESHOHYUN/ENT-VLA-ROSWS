<?xml version="1.0"?>
<?xml-model href="http://download.ros.org/schema/package_format3.xsd" schematypens="http://www.w3.org/2001/XMLSchema"?>
<package format="3">
  <name>gripper_test</name>
  <version>0.1.0</version>
  <description>Gripper control node for Faulhaber motor gripper - ROS2 port</description>
  <maintainer email="user@todo.com">user</maintainer>
  <license>MIT</license>
  <buildtool_depend>ament_cmake</buildtool_depend>
  <depend>rclcpp</depend>
  <depend>rclcpp_action</depend>
  <depend>std_msgs</depend>
  <depend>gripper_interfaces</depend>
  <build_depend>Qt5Widgets</build_depend>
  <build_depend>Qt5Core</build_depend>
  <build_depend>Qt5Gui</build_depend>
  <exec_depend>Qt5Widgets</exec_depend>
  <exec_depend>Qt5Core</exec_depend>
  <exec_depend>Qt5Gui</exec_depend>
  <test_depend>ament_lint_auto</test_depend>
  <export>
    <build_type>ament_cmake</build_type>
  </export>
</package>
